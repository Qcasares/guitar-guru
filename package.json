{
  "name": "guitar-guru",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Accessible guitar tab player — rhythm (Now/Next) + lead GODMODE (tab staff).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=guitar-guru --branch=main --commit-dirty=true"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.9",
    "wrangler": "^4.84.1"
  }
}
